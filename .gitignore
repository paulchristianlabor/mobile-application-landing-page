# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Next.js build output
.next/
out/

# Dependencies
node_modules/

# Package manager lock files (keep pnpm-lock.yaml, ignore others)
package-lock.json
yarn.lock

# TypeScript incremental build
*.tsbuildinfo
next-env.d.ts

# Environment variables
.env
.env.*
.env.local
.env.*.local
!.env.example

# IDEs and editors
.idea/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# System files
.DS_Store
Thumbs.db

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

